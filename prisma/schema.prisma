// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

/* =========================
   ENUMS
========================= */

enum AuthProvider {
  EMAIL
  APPLE
  GOOGLE
}

enum VerificationType {
  EMAIL_VERIFY
  PASSWORD_RESET
}

enum TagSource {
  EDITORIAL
  IMPORTED
  INFERRED
  USER_CONFIRMED
}

enum ImageSource {
  EDITORIAL
  OWNER
  USER
}

/* =========================
   MODELS (Registration/Auth)
========================= */

model User {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // App identity
  email       String   @unique
  firstName   String?
  lastName    String?
  displayName String?
  avatarUrl   String?
  timeZone    String   @default("America/Chicago")

  // Useful for onboarding preferences (optional; keep or drop)
  reminderOn   Boolean @default(true)
  reminderTime String? // "HH:mm"

  // Location / discovery (optional)
  city      String?
  state     String?
  latitude  Float?
  longitude Float?

  // Relations
  authIdentities     AuthIdentity[]
  sessions           Session[]
  verificationTokens VerificationToken[]
  preferredTags      UserPreferredTag[]

  @@index([createdAt])
}

model AuthIdentity {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId String
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  provider AuthProvider

  // EMAIL: normalized email; APPLE/GOOGLE: provider "sub"
  providerUserId String

  // EMAIL only (null for Apple/Google)
  passwordHash String?

  // Optional: if you want to track verification per identity
  emailVerifiedAt DateTime?

  @@unique([provider, providerUserId])
  @@index([userId])
}

model Session {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId String
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Store only a hash of refresh token (never store raw token)
  refreshTokenHash String @unique

  // Access token is typically JWT and not stored; this supports rotation/revocation.
  expiresAt DateTime
  revokedAt DateTime?

  // Optional but helpful security/audit fields
  userAgent String?
  ipAddress String?

  @@index([userId, expiresAt])
}

model VerificationToken {
  id        String           @id @default(cuid())
  createdAt DateTime         @default(now())
  expiresAt DateTime
  usedAt    DateTime?

  userId String
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  type VerificationType

  // Store only a hash of the token you email the user
  tokenHash String @unique

  @@index([userId, type, expiresAt])
}

/* =========================
   MODELS (Coffee shops & tags)
========================= */

model CoffeeShop {
  id            String   @id @default(cuid())
  name          String
  slug          String   @unique
  description   String?
  addressLine1  String?
  addressLine2  String?
  city          String
  state         String
  postalCode    String?
  country       String   @default("US")

  latitude   Float?
  longitude  Float?
  phone      String?
  websiteUrl String?
  googlePlaceId String? @unique

  // Weekly hours JSON for MVP (see plan / product docs for shape).
  hours Json?

  /// 1–5 when set: weak → strong Wi‑Fi (distinct from boolean "wifi" tag).
  wifiQuality        Int?
  /// 1 loud → 5 quiet when set.
  noiseLevel         Int?
  /// 1–5 outlet availability.
  outletAvailability Int?
  /// 1–5 seating comfort.
  seatingComfort     Int?
  /// 1–5 parking convenience.
  parkingQuality     Int?

  /// Aggregate rating for display (e.g. 4.8); optional.
  ratingAvg   Float?
  reviewCount Int?
  /// 1–4 ($–$$$$) when set.
  priceLevel  Int?

  isActive Boolean @default(true)

  tags   CoffeeShopTag[]
  images CoffeeShopImage[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([city, state])
  @@index([latitude, longitude])
}

model CoffeeShopImage {
  id           String      @id @default(cuid())
  coffeeShopId String
  url          String
  altText      String?
  sortOrder    Int         @default(0)
  source       ImageSource @default(EDITORIAL)

  coffeeShop CoffeeShop @relation(fields: [coffeeShopId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([coffeeShopId, sortOrder])
}

model TagCategory {
  id          String  @id @default(cuid())
  name        String  @unique
  slug        String  @unique
  description String?
  sortOrder   Int     @default(0)

  tags Tag[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Tag {
  id         String @id @default(cuid())
  categoryId String

  name        String
  slug        String  @unique
  description String?
  icon        String?
  sortOrder   Int     @default(0)

  isActive     Boolean @default(true)
  isFilterable Boolean @default(true)
  isPreference Boolean @default(true)

  category   TagCategory       @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  coffeeShops CoffeeShopTag[]
  userTags    UserPreferredTag[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([categoryId, name])
  @@index([categoryId, sortOrder])
}

model CoffeeShopTag {
  id           String    @id @default(cuid())
  coffeeShopId String
  tagId        String

  source     TagSource @default(EDITORIAL)
  confidence Int? // optional 1–100 for inferred/imported tags
  notes      String?

  coffeeShop CoffeeShop @relation(fields: [coffeeShopId], references: [id], onDelete: Cascade)
  tag        Tag        @relation(fields: [tagId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([coffeeShopId, tagId])
  @@index([coffeeShopId])
  @@index([tagId])
}

model UserPreferredTag {
  id     String @id @default(cuid())
  userId String
  tagId  String

  weight Int @default(1)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  tag  Tag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, tagId])
  @@index([userId])
  @@index([tagId])
}
